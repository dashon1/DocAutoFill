{
  "meta": {
    "name": "DocAutofill Minimalist",
    "version": "1.0.0",
    "viewport": { "width": 1280, "height": 720 }
  },
  "theme": {
    "colors": {
      "primary": "#212121",
      "secondary": "#616161",
      "accent": "#8BAFD0",
      "accentLight": "#F0F7FF",
      "background": "#FFFFFF",
      "surface": "#FAFAFA",
      "border": "#E0E0E0",
      "success": "#2E7D32",
      "error": "#D32F2F"
    },
    "typography": {
      "fontFamily": {
        "sans": "'Inter', 'Helvetica Neue', Arial, sans-serif",
        "code": "'JetBrains Mono', 'Fira Code', monospace"
      },
      "sizes": {
        "display": "96px",
        "h1": "64px",
        "h2": "48px",
        "h3": "32px",
        "bodyLarge": "28px",
        "body": "24px",
        "bodySmall": "22px",
        "caption": "16px"
      },
      "weights": {
        "regular": 400,
        "medium": 500,
        "bold": 700
      },
      "lineHeights": {
        "tight": 1.2,
        "standard": 1.5,
        "loose": 1.6
      }
    },
    "spacing": {
      "xs": "8px",
      "sm": "16px",
      "md": "24px",
      "lg": "32px",
      "xl": "48px",
      "xxl": "64px",
      "xxxl": "80px",
      "container": "1040px"
    },
    "layout": {
      "gridColumns": 12,
      "gridGutter": "24px",
      "margin": "60px",
      "borderRadius": {
        "sm": "4px",
        "md": "8px",
        "lg": "16px",
        "full": "9999px"
      }
    },
    "shadows": {
      "none": "none",
      "sm": "0 1px 2px rgba(0, 0, 0, 0.05)",
      "md": "0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06)",
      "lg": "0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05)",
      "product": "0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04)"
    },
    "animation": {
      "duration": {
        "fast": "150ms",
        "normal": "300ms",
        "slow": "500ms"
      },
      "easing": {
        "default": "cubic-bezier(0.4, 0, 0.2, 1)",
        "in": "cubic-bezier(0.4, 0, 1, 1)",
        "out": "cubic-bezier(0.0, 0, 0.2, 1)"
      }
    }
  }
}
